# Build artifacts that are regenerable from source via `bash build.sh [--native]`.
# The default-arena wasm engines (lisp/lisp_trampoline/lisp_gc/lisp_region/cek/
# cek_gc/bytecode/bytecode_gc) ARE tracked at the repo root so the harnesses
# work without running the build.

# Big-arena wasm variants for harness/bench.mjs
*_big.wasm

# Prototype-line wasm (optimization ladder)
bc_base.wasm
bc_inline.wasm
bc_super.wasm

# Native binaries (Mach-O / ELF, platform-specific)
native_bench_*
native_cli_*

# Disasm variant — built on demand via `bash harness/disasm.sh`
disasm.wasm

# Disasm + wasm-dispatch snapshots in project_notes/ — regenerable from the
# tools above; commit only the writeup .md files, not the captured output.
docs/project_notes/bytecode_disasm.meta.txt
docs/project_notes/wasm_dispatch.excerpt.wat
